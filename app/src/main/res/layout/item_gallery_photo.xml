<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <FrameLayout
        android:id="@+id/gallery_photo_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/gallery_photo_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FF1A1A1A"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/gallery_photo_selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#4DFF6B35"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/gallery_photo_selection_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- Top Start Badges -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:paddingStart="4dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/gallery_photo_motion_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_live_photo"
                android:tint="#FFFFFFFF"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/gallery_photo_burst_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_gallery_burst"
                android:tint="#FFFFFFFF"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Bottom Start Badges -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:paddingStart="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/gallery_photo_video_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gallery_badge_rect"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_gallery_play"
                    android:tint="#FFFFFFFF" />

                <TextView
                    android:id="@+id/gallery_photo_video_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:fontFamily="sans"
                    android:includeFontPadding="false"
                    android:textColor="#FFFFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/gallery_photo_raw_badge"
                style="@style/GallerySmallBadge"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="0dp"
                android:text="RAW"
                android:visibility="gone" />

            <TextView
                android:id="@+id/gallery_photo_imported_badge"
                style="@style/GallerySmallBadge"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/gallery_photo_related_badge"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_gallery_badge_rect"
            android:padding="2dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:src="@drawable/auto_awesome"
                android:tint="#FFFFFFFF" />
        </FrameLayout>
    </FrameLayout>
</merge>
